[ext_resource type="AudioStream" path="res://assets/sounds/The Office Gaze.mp3" id="3_bgm"]

[sub_resource type="SystemFont" id="SystemFont_mono"]
font_names = PackedStringArray("Courier New", "Consolas", "Monospace")

[sub_resource type="Shader" id="Shader_static"]
code = "shader_type canvas_item;
float random(vec2 co) {
    return fract(sin(dot(co, vec2(12.9898, 78.233))) * 43758.5453);
}
void fragment() {
    float n = random(UV + vec2(TIME * 8.0, TIME * 3.0));
    COLOR = vec4(vec3(n), 0.12);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_static"]
shader = SubResource("Shader_static")

[sub_resource type="Shader" id="Shader_grayscale"]
code = "shader_type canvas_item;
void fragment() {
    vec4 tex = texture(TEXTURE, UV);
    // Преобразование в черно-белый формат по стандарту Rec. 709
    float gray = dot(tex.rgb, vec3(0.2126, 0.7152, 0.0722));
    COLOR = vec4(vec3(gray), tex.a);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_grayscale"]
shader = SubResource("Shader_grayscale")

